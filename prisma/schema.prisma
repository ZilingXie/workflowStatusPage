generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum IncidentPriority {
  L
  M
  H
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum WorkflowRequestType {
  IMPROVEMENT
  NEW_WORKFLOW
}

enum WorkflowRequestStatus {
  PROPOSED
  CLARIFIED
  IN_PROGRESS
  DONE
  REJECTED
}

enum WorkflowRequestEventType {
  CREATED
  UPDATED
  STATUS_CHANGED
  ASSIGNEE_CHANGED
}

model Incident {
  id               String            @id @default(uuid()) @db.Uuid
  sourceInstance   String            @map("source_instance")
  workflowId       String            @map("workflow_id")
  workflowName     String            @map("workflow_name")
  executionId      String            @map("execution_id")
  failedAt         DateTime          @map("failed_at") @db.Timestamptz(6)
  errorMessage     String            @map("error_message")
  errorNodeName    String?           @map("error_node_name")
  errorType        String?           @map("error_type")
  errorStack       String?           @map("error_stack")
  executionUrl     String            @map("execution_url")
  priority         IncidentPriority  @default(L)
  status           IncidentStatus    @default(OPEN)
  resolutionReason String?           @map("resolution_reason")
  resolvedBy       String?           @map("resolved_by")
  resolvedAt       DateTime?         @map("resolved_at") @db.Timestamptz(6)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  events           IncidentEvent[]
  rawPayloads      IncidentRawPayload[]
  workflowRequests WorkflowRequest[]

  @@unique([sourceInstance, executionId])
  @@index([status])
  @@index([priority])
  @@index([failedAt(sort: Desc)])
  @@index([workflowName])
  @@index([failedAt, status])
  @@map("incidents")
}

model IncidentEvent {
  id            String         @id @default(uuid()) @db.Uuid
  incidentId    String         @map("incident_id") @db.Uuid
  fromStatus    IncidentStatus @map("from_status")
  toStatus      IncidentStatus @map("to_status")
  actionReason  String?        @map("action_reason")
  actorUsername String         @map("actor_username")
  actorRole     UserRole       @map("actor_role")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  incident      Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_events")
}

model IncidentRawPayload {
  id         String   @id @default(uuid()) @db.Uuid
  incidentId String   @map("incident_id") @db.Uuid
  payload    Json
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@map("incident_raw_payloads")
}

model WorkflowRequest {
  id                    String                 @id @default(uuid()) @db.Uuid
  type                  WorkflowRequestType
  title                 String
  description           String
  workflowName          String?                @map("workflow_name")
  workflowReference     String?                @map("workflow_reference")
  requestedWorkflowName String?                @map("requested_workflow_name")
  businessGoal          String?                @map("business_goal")
  expectedTrigger       String?                @map("expected_trigger")
  priority              IncidentPriority       @default(L)
  status                WorkflowRequestStatus  @default(PROPOSED)
  proposedBy            String                 @map("proposed_by")
  assigneeUsername      String?                @map("assignee_username")
  sourceIncidentId      String?                @map("source_incident_id") @db.Uuid
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  sourceIncident        Incident?              @relation(fields: [sourceIncidentId], references: [id], onDelete: SetNull)
  events                WorkflowRequestEvent[]
  comments              WorkflowRequestComment[]

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([workflowName])
  @@index([assigneeUsername])
  @@index([createdAt(sort: Desc)])
  @@index([sourceIncidentId])
  @@map("workflow_requests")
}

model WorkflowRequestEvent {
  id            String                 @id @default(uuid()) @db.Uuid
  requestId     String                 @map("request_id") @db.Uuid
  eventType     WorkflowRequestEventType @map("event_type")
  fromStatus    WorkflowRequestStatus? @map("from_status")
  toStatus      WorkflowRequestStatus? @map("to_status")
  fromAssignee  String?                @map("from_assignee")
  toAssignee    String?                @map("to_assignee")
  actionReason  String?                @map("action_reason")
  actorUsername String                 @map("actor_username")
  actorRole     UserRole               @map("actor_role")
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  request       WorkflowRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("workflow_request_events")
}

model WorkflowRequestComment {
  id             String          @id @default(uuid()) @db.Uuid
  requestId      String          @map("request_id") @db.Uuid
  authorUsername String          @map("author_username")
  authorRole     UserRole        @map("author_role")
  content        String
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  request        WorkflowRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("workflow_request_comments")
}

model UserAccount {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String?  @unique
  role         UserRole
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([role])
  @@map("user_accounts")
}

model AccountInvitation {
  id             String    @id @default(uuid()) @db.Uuid
  email          String
  role           UserRole  @default(OPERATOR)
  tokenHash      String    @unique @map("token_hash")
  createdBy      String    @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt         DateTime? @map("used_at") @db.Timestamptz(6)
  usedByUsername String?   @map("used_by_username")

  @@index([email])
  @@index([expiresAt])
  @@map("account_invitations")
}
