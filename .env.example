# App
NODE_ENV=production
APP_BASE_URL=https://status.example.com
TZ=UTC

# Database
DATABASE_URL=postgresql://postgres:change_me@127.0.0.1:5432/n8n_status

# Security
INGEST_TOKEN=replace_with_a_long_random_token
SESSION_SECRET=replace_with_a_long_random_session_secret

# Built-in users (JSON array string)
# Roles: ADMIN, OPERATOR
APP_USERS_JSON=[{"username":"admin","role":"ADMIN","passwordHash":"$2b$12$replace_with_admin_bcrypt_hash"},{"username":"ops1","role":"OPERATOR","passwordHash":"$2b$12$replace_with_operator_bcrypt_hash"}]
