# App
NODE_ENV=production
APP_BASE_URL=https://status.example.com
TZ=UTC

# Database
DATABASE_URL=postgresql://postgres:change_me@127.0.0.1:5432/n8n_status

# Security
INGEST_TOKEN=replace_with_a_long_random_token
SESSION_SECRET=replace_with_a_long_random_session_secret

# Accounts
# Accounts are stored in PostgreSQL table "user_accounts".
# Create initial ADMIN manually in DB; password_hash must be a bcrypt hash.
